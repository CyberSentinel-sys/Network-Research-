# Network Research Automation - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Target ────────────────────────────────────────────────
# Domain name or IP address to scan
TARGET_HOST=example.com

# ── Remote Server SSH Credentials ─────────────────────────
# Username for the remote Linux server
REMOTE_USER=your_ssh_username

# IP address or hostname of the remote server
REMOTE_HOST=your.remote.server.ip

# SSH password — prefer key-based auth; leave blank if using SSH keys
SSH_PASS=

# ── Optional: SSH Key Path ─────────────────────────────────
# Path to private key if using key-based authentication (recommended)
# SSH_KEY_PATH=~/.ssh/id_ed25519
